---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
}

const {
  title = "MásOpciones",
  description = "Laboratorio visual de datos, análisis y explicaciones públicas.",
  canonical = Astro.url.href,
  ogType = "website",
  ogImage,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="apple-touch-icon" href="/favicon.svg?v=2" />
    <meta property="og:site_name" content="MásOpciones" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    {ogImage && (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <slot />

    <footer class="site-social-footer">
      <p>También puedes encontrarnos en
        <a href="https://linkedin.com/company/masopciones" target="_blank" rel="noopener">LinkedIn</a>,
        <a href="https://instagram.com/masopcioness" target="_blank" rel="noopener">Instagram</a>,
        <a href="https://medium.com/@másopciones" target="_blank" rel="noopener">Medium</a> y
        <a href="https://github.com/MasOpciones" target="_blank" rel="noopener">GitHub</a>.
      </p>
    </footer>

    <script is:inline>
      const root = document.documentElement;

      function applyTheme(theme) {
        const isLight = theme === "light";
        root.classList.toggle("light", isLight);

        document.querySelectorAll("[data-theme-icon]").forEach((icon) => {
          icon.textContent = isLight ? "⏾" : "☀︎";
        });

        document.querySelectorAll("[data-site-logo]").forEach((logo) => {
          logo.setAttribute("src", isLight ? "/logo-negro.svg" : "/logo-blanco.svg");
        });
      }

      function initTheme() {
        const savedTheme = localStorage.getItem("theme");
        const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        const theme = savedTheme || (prefersLight ? "light" : "dark");
        applyTheme(theme);
      }

      // Corre en carga inicial y después de cada navegación del ClientRouter
      initTheme();
      document.addEventListener("astro:page-load", initTheme);

      window.toggleTheme = function () {
        const icons = document.querySelectorAll("[data-theme-icon]");
        icons.forEach((icon) => {
          icon.classList.add("animating");
        });

        const newTheme = root.classList.contains("light") ? "dark" : "light";

        setTimeout(() => {
          localStorage.setItem("theme", newTheme);
          applyTheme(newTheme);

          icons.forEach((icon) => {
            icon.classList.remove("animating");
          });
        }, 150);
      };
    </script>
  </body>
</html>
