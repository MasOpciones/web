---
interface Props {
  value: string;
  label: string;
  note?: string;
}

const { value, label, note } = Astro.props;
---

<div class="data-point" style="max-width: 42rem;">
  <p class="data-point-value">{value}</p>
  <p class="data-point-label">{label}</p>
  {note && <p class="data-point-note">{note}</p>}
</div>