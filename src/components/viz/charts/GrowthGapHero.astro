---
interface Point {
  year: number;
  special: number;
  total: number;
  definitivo: number;
}

interface Props {
  title?: string;
  subtitle?: string;
  annotationLabel?: string;
  data?: Point[];
}

const {
  title = "Índice de crecimiento acumulado",
  subtitle = "Base 100 · año 2000 · volumen encadenado",
  annotationLabel = "Post-Intel boom tech",
  data = [
    { year: 2000, special: 100, total: 100, definitivo: 100 },
    { year: 2002, special: 145, total: 112, definitivo: 108 },
    { year: 2004, special: 240, total: 132, definitivo: 126 },
    { year: 2006, special: 360, total: 156, definitivo: 148 },
    { year: 2008, special: 470, total: 179, definitivo: 166 },
    { year: 2009, special: 470, total: 182, definitivo: 168 },
    { year: 2010, special: 530, total: 194, definitivo: 176 },
    { year: 2012, special: 650, total: 217, definitivo: 191 },
    { year: 2013, special: 690, total: 226, definitivo: 198 },
    { year: 2014, special: 770, total: 238, definitivo: 208 },
    { year: 2016, special: 860, total: 264, definitivo: 228 },
    { year: 2017, special: 960, total: 279, definitivo: 239 },
    { year: 2018, special: 1030, total: 293, definitivo: 247 },
    { year: 2019, special: 1120, total: 307, definitivo: 255 },
    { year: 2020, special: 1260, total: 299, definitivo: 246 },
    { year: 2021, special: 1340, total: 316, definitivo: 258 },
    { year: 2022, special: 1450, total: 334, definitivo: 269 },
    { year: 2023, special: 1540, total: 351, definitivo: 280 },
    { year: 2024, special: 1610, total: 366, definitivo: 289 },
    { year: 2025, special: 1680, total: 378, definitivo: 296 },
  ],
} = Astro.props;

const width = 1200;
const height = 560;

const margin = {
  top: 56,
  right: 110,
  bottom: 58,
  left: 72,
};

const innerWidth = width - margin.left - margin.right;
const innerHeight = height - margin.top - margin.bottom;

const years = data.map((d) => d.year);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);

const maxValue = Math.max(...data.flatMap((d) => [d.special, d.total, d.definitivo]));
const minValue = 0;

const x = (year: number) =>
  margin.left + ((year - minYear) / (maxYear - minYear)) * innerWidth;

const y = (value: number) =>
  margin.top + (1 - (value - minValue) / (maxValue - minValue)) * innerHeight;

function buildPath(values: number[]) {
  return values
    .map((value, i) => `${i === 0 ? "M" : "L"} ${x(data[i].year).toFixed(2)} ${y(value).toFixed(2)}`)
    .join(" ");
}

const specialPath = buildPath(data.map((d) => d.special));
const totalPath = buildPath(data.map((d) => d.total));
const definitivoPath = buildPath(data.map((d) => d.definitivo));

const ticksY = [0, 300, 600, 900, 1200, 1500];
const ticksX = [2000, 2004, 2008, 2012, 2016, 2020, 2024];

const last = data[data.length - 1];
const annoYear = 2017;
const annoX = x(annoYear);
const covidStartX = x(2020) - 18;
const covidWidth = x(2021) - x(2020) + 36;
const highlightedYears = [2010, 2017, 2019, 2025];
const highlighted = data.filter((d) => highlightedYears.includes(d.year));
---

<div class="growth-hero-chart">
  <div class="growth-hero-chart-head">
    <p class="growth-hero-chart-kicker">{title}</p>
    <p class="growth-hero-chart-subtitle">{subtitle}</p>
  </div>

  <svg
    class="growth-hero-chart-svg"
    viewBox={`0 0 ${width} ${height}`}
    role="img"
    aria-label="Comparación de crecimiento acumulado entre régimen especial, PIB total y régimen definitivo"
    preserveAspectRatio="xMidYMid meet"
  >
    <defs>
      <linearGradient id="specialGlowStroke" x1="0%" x2="100%" y1="0%" y2="0%">
        <stop offset="0%" stop-color="rgba(96,255,18,0.75)" />
        <stop offset="100%" stop-color="rgba(96,255,18,1)" />
      </linearGradient>

      <linearGradient id="specialArea" x1="0%" x2="0%" y1="0%" y2="100%">
        <stop offset="0%" stop-color="rgba(96,255,18,0.14)" />
        <stop offset="100%" stop-color="rgba(96,255,18,0)" />
      </linearGradient>

      <filter id="lineGlow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!-- shaded era -->
    <rect
      x={covidStartX}
      y={margin.top}
      width={covidWidth}
      height={innerHeight}
      class="growth-era-band"
    />

    <!-- grid -->
    <g class="growth-grid">
      {ticksY.map((tick) => (
        <line x1={margin.left} y1={y(tick)} x2={width - margin.right} y2={y(tick)} />
      ))}

      {ticksX.map((tick) => (
        <line x1={x(tick)} y1={margin.top} x2={x(tick)} y2={height - margin.bottom} />
      ))}
    </g>

    <!-- axes -->
    <g class="growth-axes">
      <line x1={margin.left} y1={height - margin.bottom} x2={width - margin.right} y2={height - margin.bottom} />
      <line x1={margin.left} y1={margin.top} x2={margin.left} y2={height - margin.bottom} />
    </g>

    <!-- y labels -->
    <g class="growth-axis-labels">
      {ticksY.map((tick) => (
        <text x={margin.left - 12} y={y(tick) + 4} text-anchor="end">
          {tick}
        </text>
      ))}
    </g>

    <!-- x labels -->
    <g class="growth-axis-labels">
      {ticksX.map((tick) => (
        <text x={x(tick)} y={height - margin.bottom + 24} text-anchor="middle">
          {tick}
        </text>
      ))}
    </g>

    <!-- annotation -->
    <g class="growth-annotation">
      <line x1={annoX} y1={y(980)} x2={annoX} y2={height - margin.bottom} />
      <text x={annoX - 18} y={y(980) - 14}>{annotationLabel}</text>
    </g>

    <g class="growth-annotation growth-annotation--covid">
      <text x={covidStartX + 8} y={margin.top + 18}>COVID</text>
    </g>

    <!-- secondary lines -->
    <path d={definitivoPath} class="growth-line growth-line--definitivo" />
    <path d={totalPath} class="growth-line growth-line--total" />

    <!-- primary area -->
    <path
      d={`${specialPath} L ${x(last.year)} ${height - margin.bottom} L ${x(data[0].year)} ${height - margin.bottom} Z`}
      class="growth-area"
    />

    <!-- primary line -->
    <path d={specialPath} class="growth-line growth-line--special-glow" filter="url(#lineGlow)" />
    <path d={specialPath} class="growth-line growth-line--special" />

    <!-- highlighted points -->
    {highlighted.map((d) => (
      <g class="growth-point-group">
        <circle cx={x(d.year)} cy={y(d.special)} r="8" class="growth-point growth-point--outer" />
        <circle cx={x(d.year)} cy={y(d.special)} r="4" class="growth-point growth-point--inner" />
      </g>
    ))}

    <!-- end labels -->
    <g class="growth-end-labels">
      <text x={x(last.year) + 10} y={y(last.special) + 4} class="growth-end-label growth-end-label--special">
        1,338
      </text>
      <text x={x(last.year) + 10} y={y(last.total) + 4} class="growth-end-label growth-end-label--total">
        378
      </text>
      <text x={x(last.year) + 10} y={y(last.definitivo) + 4} class="growth-end-label growth-end-label--definitivo">
        296
      </text>
    </g>

    <!-- axis names -->
    <text
      x={width / 2}
      y={height - 10}
      text-anchor="middle"
      class="growth-axis-title"
    >
      AÑO
    </text>

    <text
      x="20"
      y={height / 2}
      text-anchor="middle"
      transform={`rotate(-90 20 ${height / 2})`}
      class="growth-axis-title"
    >
      ÍNDICE (BASE 100)
    </text>
  </svg>

  <div class="growth-legend">
    <div class="growth-legend-item">
      <span class="growth-legend-swatch growth-legend-swatch--special"></span>
      <span>Régimen especial (zona franca)</span>
    </div>
    <div class="growth-legend-item">
      <span class="growth-legend-swatch growth-legend-swatch--total"></span>
      <span>PIB total</span>
    </div>
    <div class="growth-legend-item">
      <span class="growth-legend-swatch growth-legend-swatch--definitivo"></span>
      <span>Régimen definitivo</span>
    </div>
  </div>
</div>